generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  nickname      String?
  population    String         @default("adults")
  wasteReduced  Float          @default(0)
  waterSaved    Float          @default(0)
  co2Reduced    Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  intakeRecords IntakeRecord[]
  fridgeItems   FridgeItem[]
  shoppingItems ShoppingItem[]
  chatMessages  ChatMessage[]
}

model IntakeRecord {
  id         String   @id @default(cuid())
  date       String
  time       String
  vegetables Int
  fruits     Int
  meat       Int
  eggs       Int
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FridgeItem {
  id        String   @id @default(cuid())
  name      String
  quantity  Int
  unit      String   @default("g")
  addedDate String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShoppingItem {
  id        String   @id @default(cuid())
  name      String
  note      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
